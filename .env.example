APP_NAME="Coupons & Stores Admin"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=goldencoupon
DB_USERNAME=root
DB_PASSWORD=

# Cache, queue, session
# CACHE_STORE is the Laravel 11+ name. CACHE_DRIVER is still read for BC.
CACHE_STORE=file
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Comma separated origins allowed by HandleCors. Use * for local development.
ALLOW_CORS=*

# Comma separated trusted proxy IPs/CIDRs (leave empty for local).
TRUSTED_IP_ADDRESS=

# Local path used by the `front` filesystem disk to share media with the
# public-facing site. Falls back to storage/app/front if unset.
FRONT_END_STORAGE_PATH=

# Mail (uses array driver in tests; smtp/log are common locally)
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@example.test"
MAIL_FROM_NAME="${APP_NAME}"

# Broadcasting / Redis (only needed if you switch drivers above)
BROADCAST_DRIVER=log
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# AWS (only needed if you switch the `s3` filesystem disk on)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
